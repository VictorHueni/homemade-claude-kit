variable "zone" {
  description = "Exoscale zone (ch-gva-2, ch-dk-2, de-fra-1, de-muc-1, at-vie-1, at-vie-2, bg-sof-1)."
  type        = string
  default     = "ch-gva-2"

  validation {
    condition     = contains(["ch-gva-2", "ch-dk-2", "de-fra-1", "de-muc-1", "at-vie-1", "at-vie-2", "bg-sof-1"], var.zone)
    error_message = "zone must be a valid Exoscale zone."
  }
}

variable "instance_type" {
  description = "Compute instance type, e.g. standard.medium."
  type        = string
  default     = "standard.medium"
}

variable "admin_cidr" {
  description = "CIDR allowed to reach admin ports (SSH). Do not use 0.0.0.0/0."
  type        = string
}
