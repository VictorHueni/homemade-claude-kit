<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{TITLE}}</title>
<style>
/* ===== 1. Design-system tokens (defaults; project sheet, if any, follows and wins) ===== */
{{DESIGN_SYSTEM_CSS}}

/* ===== 2. Baseline layout (token-driven; never hard-codes colour) ===== */
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
body {
  font-family: var(--font-sans, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif);
  color: var(--ink, #1a1a1a);
  background: var(--canvas-bg, #f6f7f9);
  line-height: 1.45;
}
.viz-shell { max-width: var(--shell-max, 1400px); margin: 0 auto; padding: var(--space-lg, 2rem); }
.viz-header { display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.75rem; margin-bottom: 0.25rem; }
.viz-title { font-size: var(--title-size, 1.6rem); font-weight: 700; margin: 0; }
.viz-kind  { font-family: var(--font-mono, ui-monospace, monospace); font-size: 0.7rem; text-transform: uppercase;
             letter-spacing: 0.08em; color: var(--muted, #6b7280); border: 1px solid var(--border, #d1d5db);
             padding: 0.1rem 0.45rem; border-radius: 999px; }
.viz-meta  { font-size: 0.8rem; color: var(--muted, #6b7280); margin: 0 0 1.25rem; }
.viz-toolbar { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.25rem; }
.viz-btn {
  font: inherit; font-size: 0.8rem; cursor: pointer;
  background: var(--surface, #fff); color: var(--ink, #1a1a1a);
  border: 1px solid var(--border, #d1d5db); border-radius: var(--btn-radius, 8px);
  padding: 0.35rem 0.7rem; transition: background .12s ease, border-color .12s ease;
}
.viz-btn:hover { border-color: var(--accent, #3b6ef5); }
.viz-btn[aria-pressed="true"] { background: var(--accent, #3b6ef5); color: var(--accent-ink, #fff); border-color: var(--accent, #3b6ef5); }
.viz-empty { color: var(--muted, #6b7280); font-style: italic; padding: 2rem 0; }
.viz-footer { margin-top: 2rem; font-size: 0.72rem; color: var(--muted, #6b7280);
              border-top: 1px solid var(--border, #d1d5db); padding-top: 0.75rem; }

/* ===== 3. View-specific CSS (emitted by the renderer) ===== */
{{VIEW_CSS}}
</style>
</head>
<body>
<div class="viz-shell">
  <header class="viz-header">
    <h1 class="viz-title">{{TITLE}}</h1>
    <span class="viz-kind">{{KIND}}</span>
  </header>
  <p class="viz-meta">{{META}}</p>
  <div class="viz-toolbar">{{TOOLBAR}}</div>
  <main class="viz-content">
{{CONTENT}}
  </main>
  <footer class="viz-footer">{{FOOTER}}</footer>
</div>
<script>
{{RUNTIME_JS}}
</script>
</body>
</html>
